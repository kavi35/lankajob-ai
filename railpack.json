{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "steps": {
    "install": {
      "commands": ["npm install --legacy-peer-deps"]
    },
    "build": {
      "commands": ["npm run build --workspace=web"]
    }
  },
  "deploy": {
    "startCommand": "npm run start --workspace=web"
  }
}
