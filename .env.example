# Frontend (apps/web/.env.local)

# --- Vercel-only (no database, no Railway) ---
# Leave API URL empty OR set standalone flag:
NEXT_PUBLIC_STANDALONE=true
# NEXT_PUBLIC_API_URL=

# --- Optional: Clerk auth ---
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# --- Full stack (with Railway API + Supabase) ---
# NEXT_PUBLIC_STANDALONE=false
# NEXT_PUBLIC_API_URL=https://your-api.railway.app

# Backend (apps/api/.env) — only if using Railway API
DATABASE_URL=postgresql+asyncpg://lankajob:lankajob@localhost:5432/lankajob
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=cvs
OPENAI_API_KEY=sk-proj-your-openai-key-here
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev
CLERK_WEBHOOK_SECRET=whsec_...
SERPAPI_KEY=your-serpapi-key
CORS_ORIGINS=http://localhost:3000
